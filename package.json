{
  "name": "mission-control",
  "version": "0.1.0",
  "private": true,
  "description": "Launchpad — browser terminal + agent pad (real local PTY in a tab)",
  "scripts": {
    "terminal": "node terminal/start.mjs",
    "terminal:pty": "node terminal/pty-server.mjs",
    "terminal:html": "bun run terminal/server.ts",
    "terminal:launcher:build": "node terminal/build-launcher.mjs",
    "terminal:launcher:install": "node terminal/build-launcher.mjs",
    "terminal:install": "bun run terminal:launcher:install && ./terminal/install-launch-agent.sh",
    "start": "node terminal/start.mjs",
    "dev": "node terminal/start.mjs",
    "install:service": "./terminal/install-launch-agent.sh"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "typescript": "^5"
  }
}
